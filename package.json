{
  "name": "n-of-m-web",
  "private": true,
  "version": "0.3.3",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && bun scripts/bundle-single-file.ts",
    "preview": "vite preview",
    "deploy": "vite build && npx wrangler deploy",
    "deploy:vercel": "vercel --prod",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/ciphers": "^2.1.1",
    "@sveltejs/kit": "^2.53.3",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "buffer": "^6.0.3",
    "ethers": "^6.16.0",
    "html2pdf.js": "^0.14.0",
    "jsqr": "^1.4.0",
    "pdfjs-dist": "^4.0.379",
    "qr-scanner": "^1.4.2",
    "qrious": "^4.0.2",
    "svelte": "^5.53.0",
    "uuid": "^13.0.0",
    "vite": "^7.3.1"
  },
  "overrides": {
    "cookie": "^0.7.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/adapter-static": "^3.0.10",
    "@types/uuid": "^11.0.0",
    "svelte-check": "^4.4.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
